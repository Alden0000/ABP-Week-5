<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whiteknight — Membership System</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <style>
        :root {
            /* PALET OFF-WHITE MULTI-LAYER */
            --bg-body: #F8F9FA;         /* Ghost White / Alabaster */
            --bg-sidebar: #FFFFF0;      /* Ivory */
            --bg-card: #FFFFFF;         /* Pure White */
            --bg-input: #F0F8FF;        /* Alice Blue (sangat lembut kebiruan) */
            --bg-header-table: #F5F5F5; /* White Smoke */
            --bg-active-link: #FDF5E6;  /* Old Lace (hangat lembut) */
            
            /* Warna Teks & Aksen */
            --text-main: #4A4A4A;       /* Charcoal soft */
            --text-sidebar: #6B6B5F;    /* Sage-tinted Grey */
            --text-label: #A8A89A;      /* Bone Grey */
            --border-color: #EDEADE;    /* Eggshell (border tipis) */
            --accent-pearl: #FBFCF8;    /* Cosmic Latte / Pearl */
        }

        body { 
            background-color: var(--bg-body); 
            font-family: 'Inter', sans-serif; 
            margin: 0; 
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
        }

        /* --- SIDEBAR (Ivory & Old Lace) --- */
        .sidebar {
            position: fixed; top: 0; left: 0; width: 280px; height: 100vh;
            background-color: var(--bg-sidebar); 
            z-index: 1000; padding-top: 25px;
            border-right: 1px solid var(--border-color);
        }

        .sidebar-brand { 
            padding: 0 40px; 
            font-size: 1.5rem; 
            font-weight: 800; 
            color: #FFFFFF; 
            margin-bottom: 40px; 
            display: flex; 
            align-items: center; 
            gap: 12px;
            /* Shadow menggunakan warna Bone agar teks putih "mengambang" */
            text-shadow: 2px 2px 0px #E3E4D7; 
        }

        .nav-label { 
            padding-left: 40px; 
            font-size: 0.7rem; 
            text-transform: uppercase; 
            letter-spacing: 1.5px; 
            color: var(--text-label); 
            margin-top: 25px; 
        }

        .nav-pills .nav-link { 
            color: var(--text-sidebar); 
            padding: 12px 40px; 
            border-radius: 0;
            border-left: 4px solid transparent;
            transition: 0.2s;
        }
        
        .nav-pills .nav-link:hover { 
            background-color: var(--accent-pearl); 
            color: #000; 
        }

        .nav-pills .nav-link.active { 
            background-color: var(--bg-active-link); 
            color: #8B8B7A; 
            border-left: 4px solid #F5F5DC; /* Beige border */
            font-weight: 700;
        }

        /* --- MAIN CONTENT (Pure White & Ghost White) --- */
        .main-content { margin-left: 280px; padding: 40px; }
        
        /* Card bergaya Pearl/Mutiara */
        .card-custom { 
            background: var(--bg-card); 
            border: 1px solid var(--border-color); 
            border-radius: 16px; 
            padding: 30px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.03); 
            margin-bottom: 25px; 
        }

        .stat-card {
            background: linear-gradient(145deg, #ffffff, #f0f0f0); /* Subtle gradient putih */
            border: 1px solid var(--border-color);
        }
        
        .d-none { display: none !important; }

        /* Button - Putih Kristal */
        .btn-dark { 
            background-color: #FFFFFF; 
            color: #555; 
            border: 1px solid #DCDCDC; /* Gainsboro */
            font-weight: 600; 
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }
        .btn-dark:hover { background-color: #FFFAFA; border-color: #CCC; color: #000; }

        /* Input bergaya Alice Blue (Biru Putih) */
        .form-control, .form-select {
            background-color: var(--bg-input);
            border: 1px solid #E1E8ED;
            color: var(--text-main);
            border-radius: 8px;
        }
        .form-control:focus {
            background-color: #FFFFFF;
            border-color: #ADD8E6; /* Light Blue focus */
            box-shadow: 0 0 0 0.25rem rgba(173, 216, 230, 0.2);
        }

        /* Table Styling - White Smoke & Snow */
        .table thead { background-color: var(--bg-header-table); }
        .table-hover tbody tr:hover { background-color: #FFFAFA; }
        
        h2, h4, h5 { color: #5F5F5F; letter-spacing: -0.5px; }
        
        .badge-aktif { background-color: #F0FFF0; color: #2E8B57; border: 1px solid #98FB98; }
        .badge-standby { background-color: #FFFFF0; color: #8B8B00; border: 1px solid #EEE8AA; }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-shield-check" style="color: #F5F5F5;"></i>
            <span>WHITE<span>KNIGHT</span></span>
        </div>
        
        <div class="nav flex-column nav-pills">
            <span class="nav-label">Main Command</span>
            <a class="nav-link active" id="menu-dashboard">
                <i class="bi bi-house-door me-2"></i> Dashboard
            </a>
            <a class="nav-link" id="menu-tambah" onclick="resetForm()">
                <i class="bi bi-plus-circle me-2"></i> New Personnel
            </a>
            <a class="nav-link" id="menu-data">
                <i class="bi bi-layers me-2"></i> Archives
            </a>
        </div>
    </aside>

    <main class="main-content">
        <!-- DASHBOARD SECTION -->
        <div id="section-dashboard">
            <div class="mb-5">
                <h2 class="fw-bold">System Overview</h2>
                <p style="color: var(--text-label);">Operational status of the Whiteknight Network</p>
            </div>
            
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card-custom stat-card">
                        <h6 class="small fw-bold text-uppercase" style="color: var(--text-label);">Total Squad</h6>
                        <h2 class="fw-bold m-0" id="stat-total" style="color: #6B6B5F;">0</h2>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card-custom stat-card" style="border-top: 4px solid #F0FFF0;">
                        <h6 class="small fw-bold text-uppercase" style="color: var(--text-label);">Active Duty</h6>
                        <h2 class="fw-bold m-0" id="stat-aktif" style="color: #2E8B57;">0</h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- FORM SECTION -->
        <div id="section-tambah" class="d-none">
            <div class="card-custom" style="background: #FFFEFA;"> <!-- Floral White tint -->
                <h4 id="form-title" class="fw-bold mb-4">Registry Entry</h4>
                <form id="formMember">
                    <input type="hidden" id="member-id">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">IDENTIFICATION CODE</label>
                            <input type="text" id="in-code" class="form-control" placeholder="WK-XXXX" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">OPERATIVE NAME</label>
                            <input type="text" id="in-nama" class="form-control" placeholder="Full Name" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">RANK / DIVISION</label>
                            <select id="in-rank" class="form-select">
                                <option>Grand Master</option>
                                <option>Vanguard</option>
                                <option>Shadow Ops</option>
                                <option>Cyber Security</option>
                                <option>Strategist</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">DEPLOYMENT STATUS</label>
                            <select id="in-status" class="form-select">
                                <option value="Aktif">Aktif</option>
                                <option value="Standby">Standby</option>
                                <option value="Retired">Retired</option>
                            </select>
                        </div>
                        <div class="col-12 text-end">
                            <button type="submit" id="btn-submit" class="btn btn-dark px-5 py-2">Confirm Deployment</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- TABLE SECTION -->
        <div id="section-data" class="d-none">
            <div class="card-custom">
                <div class="table-responsive">
                    <table id="tableMember" class="table w-100">
                        <thead>
                            <tr>
                                <th class="py-3">CODE</th>
                                <th class="py-3">OPERATIVE</th>
                                <th class="py-3">DIVISION</th>
                                <th class="py-3">STATUS</th>
                                <th class="py-3">OPS</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function() {
            const table = $('#tableMember').DataTable({
                ajax: { url: '/api/member', dataSrc: 'data' },
                columns: [
                    { data: 'nim', className: 'fw-bold text-secondary' },
                    { data: 'nama' },
                    { data: 'prodi' },
                    { 
                        data: 'status',
                        render: (d) => {
                            let cls = d === 'Aktif' ? 'badge-aktif' : 'badge-standby';
                            return `<span class="badge ${cls} p-2 px-3">${d}</span>`;
                        }
                    },
                    {
                        data: 'id',
                        render: (id) => `
                            <button class="btn btn-sm btn-light border-0" onclick="prepareEdit('${id}')"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-light border-0 text-danger" onclick="hapus('${id}')"><i class="bi bi-trash"></i></button>
                        `
                    }
                ],
                language: { search: "_INPUT_", searchPlaceholder: "Search Archives..." }
            });

            $('.nav-link').on('click', function() {
                $('.nav-link').removeClass('active');
                $(this).addClass('active');
                const id = $(this).attr('id');
                $('#section-dashboard, #section-tambah, #section-data').addClass('d-none');
                if(id === 'menu-dashboard') { $('#section-dashboard').removeClass('d-none'); loadStats(); }
                else if(id === 'menu-tambah') { $('#section-tambah').removeClass('d-none'); }
                else if(id === 'menu-data') { $('#section-data').removeClass('d-none'); table.ajax.reload(); }
            });

            $('#formMember').on('submit', function(e) {
                e.preventDefault();
                const id = $('#member-id').val();
                const data = {
                    nim: $('#in-code').val(),
                    nama: $('#in-nama').val(),
                    prodi: $('#in-rank').val(),
                    status: $('#in-status').val()
                };
                const type = id ? 'PUT' : 'POST';
                $.ajax({
                    url: id ? `/api/member/${id}` : '/api/member',
                    type: type,
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    success: function() {
                        resetForm();
                        $('#menu-data').click(); 
                    }
                });
            });
            loadStats();
        });

        function loadStats() {
            $.get('/api/statistik', (data) => {
                $('#stat-total').text(data.total);
                $('#stat-aktif').text(data.aktif);
            });
        }

        function prepareEdit(id) {
            $.get('/api/member', function(res) {
                const m = res.data.find(i => i.id === id);
                if(m) {
                    $('#member-id').val(m.id);
                    $('#in-code').val(m.nim);
                    $('#in-nama').val(m.nama);
                    $('#in-rank').val(m.prodi);
                    $('#in-status').val(m.status);
                    $('#form-title').text('Update Operative');
                    $('#menu-tambah').click();
                }
            });
        }

        function resetForm() {
            $('#member-id').val('');
            $('#formMember')[0].reset();
            $('#form-title').text('Registry Entry');
        }

        function hapus(id) {
            if(confirm('Purge this record?')) {
                $.ajax({
                    url: '/api/member/' + id,
                    type: 'DELETE',
                    success: () => { $('#tableMember').DataTable().ajax.reload(); loadStats(); }
                });
            }
        }
    </script>
</body>
</html>